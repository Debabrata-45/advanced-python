        print("  1.  Add New Task")
        print("  2.  Mark Task as Done")
        print("  3.  Mark Task as Pending")
        print("  4.  Delete Task")
        print("  5.  Show All Tasks")
        print("  6.  Show Pending Tasks")
        print("  7.  Show Completed Tasks")
        print("  8.  Show Overdue Tasks")
        print("  9.  Filter by Project")
        print("  10. Filter by Tag")
        print("  11. Filter by Priority")
        print("  12. Show Summary")
        print("  13. Exit")
        print("="*42)

        choice = input("  Enter choice (1-13): ").strip()

        if choice == "1":
            title    = input("  Task Title       : ").strip()
            deadline = input("  Deadline (YYYY-MM-DD): ").strip()
            print("  Priority options : High / Medium / Low")
            priority = input("  Priority         : ").strip().capitalize() or "Medium"
            project  = input("  Project Name     : ").strip() or "General"
            tags     = input("  Tags (comma separated): ").strip()
            manager.add_task(title, deadline, priority, project, tags)

        elif choice == "2":
            tid = int(input("  Task ID to mark DONE: "))
            manager.mark_task_done(tid)

        elif choice == "3":
            tid = int(input("  Task ID to mark PENDING: "))
            manager.mark_task_pending(tid)

        elif choice == "4":
            tid = int(input("  Task ID to delete: "))
            manager.delete_task(tid)

        elif choice == "5":
            manager.show_all()

        elif choice == "6":
            manager.show_pending()

        elif choice == "7":
            manager.show_completed()

        elif choice == "8":
            manager.show_overdue()

        elif choice == "9":
            proj = input("  Enter Project Name: ").strip()
            manager.filter_by_project(proj)

        elif choice == "10":
            tag = input("  Enter Tag: ").strip()
            manager.filter_by_tag(tag)

        elif choice == "11":
            print("  Priority options: High / Medium / Low")
            p = input("  Enter Priority: ").strip().capitalize()
            manager.filter_by_priority(p)

        elif choice == "12":
            manager.show_summary()

        elif choice == "13":
            print("\n  👋 Goodbye! Stay productive.")
            break

        else:
            print("  ⚠️  Invalid choice.")


if __name__ == "__main__":
    main()
#  Menu-Driven Main Program
# ─────────────────────────────────────────────

def main():
    cinema = Cinema("CinePlex Multiplex")

    # Pre-loaded shows
    today = datetime.date.today().strftime("%d-%m-%Y")
    cinema.add_show("Pushpa 2",      "Hall A", "Morning",   today)
    cinema.add_show("Kalki 2898 AD", "Hall B", "Evening",   today)
    cinema.add_show("RRR",           "Hall A", "Night",     today)
    cinema.add_show("Dune Part 2",   "Hall C", "Afternoon", today)

    while True:
        print("\n" + "="*42)
        print("   🎬 MOVIE TICKET BOOKING SYSTEM")
        print("="*42)
        print("  1. View All Shows")
        print("  2. View Seat Layout (for a show)")
        print("  3. Book Tickets")
        print("  4. Cancel Booking")
        print("  5. View Booking Details")
        print("  6. Add New Show (Admin)")
        print("  7. Exit")
        print("="*42)

        choice = input("  Enter choice (1-7): ").strip()

        if choice == "1":
            cinema.list_shows()

        elif choice == "2":
            cinema.list_shows()
            try:
                idx = int(input("  Enter Show Number: ")) - 1
                show = cinema.shows[idx]
                print(f"\n  🎥 Seat Layout: {show.movie_name} | {show.slot}")
                print("  Rows A-B: VIP | C-D: Premium | E-H: Standard")
                show.seat_grid.display()
            except (ValueError, IndexError):
                print("  ❌ Invalid show number.")

        elif choice == "3":
            cinema.list_shows()
            try:
                idx = int(input("  Enter Show Number: ")) - 1
                show = cinema.shows[idx]
                show.seat_grid.display()

                name  = input("\n  Customer Name : ").strip()
                phone = input("  Phone Number  : ").strip()
                seats_input = input("  Enter Seat Labels (e.g. A1,A2,B3): ").strip()
                seat_list = [s.strip() for s in seats_input.split(",") if s.strip()]

                if not seat_list:
                    print("  ❌ No seats entered.")
                else:
                    cinema.book_tickets(idx, name, phone, seat_list)
            except (ValueError, IndexError):
                print("  ❌ Invalid show number.")

        elif choice == "4":
            bid = input("  Enter Booking ID to cancel: ").strip().upper()
            cinema.cancel_booking(bid)

        elif choice == "5":
            bid = input("  Enter Booking ID: ").strip().upper()
            cinema.view_booking(bid)

        elif choice == "6":
            movie = input("  Movie Name    : ").strip()
            hall  = input("  Hall Name     : ").strip()
            print("  Slots: Morning / Afternoon / Evening / Night")
            slot  = input("  Slot          : ").strip().capitalize()
            date  = input("  Date (DD-MM-YYYY): ").strip() or today
            if slot not in TICKET_PRICES:
                print("  ❌ Invalid slot.")
            else:
                cinema.add_show(movie, hall, slot, date)

        elif choice == "7":
            print("\n  🎬 Thank you! Enjoy the movies!")
            break

        else:
            print("  ⚠️  Invalid choice.")


if __name__ == "__main__":
    main()